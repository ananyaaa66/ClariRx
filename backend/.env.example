# ── LLM API Keys (fill in at least one) ──
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ── Model preferences ──
# Options: "openai" or "gemini"
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# ── OCR settings ──
# Options: "paddleocr" or "llm_vision"
DEFAULT_OCR_METHOD=paddleocr

# ── Extraction settings ──
# Options: "llm" or "biobert"
DEFAULT_EXTRACTION_METHOD=llm

# ── App settings ──
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
